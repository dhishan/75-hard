# Firebase — get these from Firebase Console > Project Settings > Your apps
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-gcp-project-id

# API — backend URL (leave empty for local dev with Vite proxy)
VITE_API_URL=https://api.75hard.blueelephants.org/api/v1
